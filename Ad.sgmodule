#!name=节点阻断检测看板
#!arguments=Proxy:Proxy
#!arguments-desc=Proxy: 选择策略组,默认Proxy


[Panel]
# 节点阻断检测看板
# 提示：请确保 script-path 指向你实际存放该 js 脚本的路径
block_check = script-name=block_check, title="节点阻断检测", update-interval=10

[Script]
# 脚本注册
block_check = type=generic, timeout=15, script-path=https://raw.githubusercontent.com/BOBOLAOSHIV587/zTest/refs/heads/main/KG.js, argument=Proxy={{{Proxy}}}
